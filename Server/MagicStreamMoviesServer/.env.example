# ============================================
# SLIX BACKEND - PRODUCTION ENVIRONMENT
# ============================================

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/slix?retryWrites=true&w=majority
DATABASE_NAME=slix_production

# JWT Secret Keys (REQUIRED - generate strong random keys)
# Generate with: openssl rand -base64 32
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-base64-32
SECRET_REFRESH_KEY=your-refresh-secret-key-here-generate-with-openssl-rand-base64-32

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app

# Cookie Domain (set to your backend domain on Render)
COOKIE_DOMAIN=your-backend.onrender.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Azure OpenAI (if using AI features)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Recommendation Settings
RECOMMENDED_MOVIE_LIMIT=5

# Server Port (Render sets this automatically, but can override)
PORT=8080
